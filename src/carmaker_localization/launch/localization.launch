<launch>
    <!-- Arguments -->
    <arg name="foxglove" default="false" />
    <arg name="use_sim_time" default="false" />
    <arg name="landmark_file" default="$(find carmaker_localization)/config/Test.osm" />

    <!-- Global parameter -->
    <param name="use_sim_time" value="$(arg use_sim_time)" />

    <!-- Nodelet Manager -->
    <node pkg="nodelet" type="nodelet" name="localization_manager" args="manager" output="screen" />

    <!-- carmaker_localization Nodelet -->
    <node pkg="nodelet" type="nodelet" name="LocalizationNodelet" args="load carmaker_localization/LocalizationNodelet localization_manager" output="screen">

        <!-- Load Parameters -->
        <rosparam command="load" file="$(find carmaker_localization)/config/localization_params.yaml" />
        <rosparam command="load" file="$(find carmaker_localization)/config/vehicle_params.yaml" />

        <!-- Overwrite landmark file path -->
        <param name="feature_registration/landmark_file" value="$(arg landmark_file)" />
    </node>

    <!-- Foxglove Bridge for Visualization (Optional) -->
    <group if="$(arg foxglove)">
        <include file="$(find foxglove_bridge)/launch/foxglove_bridge.launch" >
        <arg name="port" value="8765" />
        </include>
    </group>
</launch>
