<launch>
  <arg name="config"
    default="$(find carmaker_image)/config/segmentation_unet.yaml" />
  <arg name="data_root"
    default="$(find carmaker_image)/data" />
  <arg name="manifest"
    default="$(find carmaker_image)/data/csv/manifest.csv" />
  <arg name="run_dir"
    default="$(find carmaker_image)/runs/unet_carmaker" />
  <arg name="epochs"
    default="0" />
  <arg name="batch_size"
    default="0" />
  <arg name="device"
    default="auto" />
  <arg name="overfit_count"
    default="0" />

  <node pkg="carmaker_image"
    type="segmentation_train.py"
    name="segmentation_train"
    output="screen"
    args="--config $(arg config)
          --data-root $(arg data_root)
          --manifest $(arg manifest)
          --run-dir $(arg run_dir)
          --epochs $(arg epochs)
          --batch-size $(arg batch_size)
          --device $(arg device)
          --overfit-count $(arg overfit_count)" />
</launch>
